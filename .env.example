# =============================================================================
# RankPilot SEO — copy to backend/.env
# Product brief (April 2026): seven SEO features only — Maps ranks, auto-content, GBP, citations,
# review velocity, organic keyword monitor, monthly report. No AEO/GEO scope in this codebase.
# TR = Traffic Radius holds the key (server-side, never exposed to client)
# CLIENT = per-tenant OAuth tokens stored in DB (rp_clients.*)
#
# Stack note: the brief lists Next.js + Supabase; this repo uses FastAPI + React (Vite).
# The data layer is the same idea: PostgreSQL with Row-Level Security (see infra/sql).
# =============================================================================

# --- Database (required) — PostgreSQL only ---
# RankPilot stores all tenant data in PostgreSQL (rp_clients, rp_suburb_grid, rp_rank_history,
# rp_content_queue, rp_jobs, rp_citations, …). Use any Postgres 16+ host (local, RDS, Neon, etc.).
# Driver must be asyncpg. Special chars in password must be URL-encoded (@ → %40).
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD%40@localhost:5432/rankpilot
REDIS_URL=redis://localhost:6379/0

# --- JWT signing (optional locally — auto dev-secret if blank or weak) ---
# Production: set a long random string e.g. openssl rand -base64 48
# JWT_SECRET_KEY=

# =============================================================================
# TR-OWNED keys (Traffic Radius server — all clients share these)
# =============================================================================

# --- DataForSEO [TR] — Maps local pack, SERP, keyword data ---
# Owner: TR. Phase 1: YES 100%.
# Also accepted: DATAFORSEO_API_LOGIN, DATAFORSEO_USER / DATAFORSEO_API_PASSWORD, DATAFORSEO_SECRET
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# --- Anthropic / Claude [TR] — Content queue, reports, chat ---
# Owner: TR. Phase 1: YES 100%.
ANTHROPIC_API_KEY=
# Optional model override for content generation (default: claude-sonnet-4-6)
# ANTHROPIC_CONTENT_MODEL=

# --- OpenAI [TR] — Embeddings (text-embedding-3-small), optional GPT tools ---
# Owner: TR. Phase 1: YES 100%.
OPENAI_API_KEY=

# --- Google PageSpeed Insights [TR] — Technical audit ---
# Owner: TR. Phase 1: YES 100%.
GOOGLE_PAGESPEED_KEY=

# --- Google Rich Results Test API [TR] — Schema / AEO validator ---
# Owner: TR. Phase 1: YES 100%.
GOOGLE_RICH_RESULTS_KEY=

# --- Google Knowledge Graph API [TR] — Entity / brand signals ---
# Owner: TR.
GOOGLE_KG_API_KEY=

# --- Google Places API [TR] — GBP read via DataForSEO substitute ---
# Owner: TR.
GOOGLE_PLACES_API_KEY=

# --- Firecrawl [TR] — directory/citation page scraping ---
# Owner: TR. Use this for citations crawling/extraction.
FIRECRAWL_API_KEY=
# Backward-compat alias still accepted by config:
# BRIGHT_DATA_API_TOKEN=

# --- SendGrid [TR] — All transactional email ---
# Owner: TR. Phase 1: YES 100%.
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# --- Twilio [TR] — SMS / voice notifications ---
# Owner: TR. Phase 1: YES 100%.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# --- Stripe [TR] — Billing ---
# Owner: TR. Phase 1: YES 100%.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# =============================================================================
# CLIENT-OWNED OAuth keys (Google APIs — per-tenant, stored in rp_clients)
# These are your Google Cloud OAuth app credentials (consent screen / app registration).
# Each client authorises via OAuth 2.0; tokens stored per-tenant in DB.
# =============================================================================

# --- Google OAuth App [CLIENT] — covers GSC, GA4, GBP, YouTube ---
# Owner: CLIENT. Phase 1: Partial (DataForSEO substitute for read).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# =============================================================================
# Frontend (Vite) — only VITE_ prefix vars are exposed to browser
# =============================================================================
VITE_API_BASE_URL=http://localhost:8000

# --- API CORS (comma-separated) — must include your Vite origin ---
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
